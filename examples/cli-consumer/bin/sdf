#!/usr/bin/env bash
# sdf — a command-line client for the semanticdf REST API.
#
# Usage: sdf <command> [options]
# Run `sdf --help` for the full command reference.
#
# Installation: either run directly (`./bin/sdf`) or symlink into your PATH:
#   ln -s "$(pwd)/bin/sdf" /usr/local/bin/sdf
#   ln -s "$(pwd)/bin/semanticdf" /usr/local/bin/semanticdf
#
# Requirements: mvn, java 17+ on PATH. Run `mvn compile` once before first use.

set -euo pipefail

# Resolve the project root from this script's location (bin/ is one level deep).
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

cd "$PROJECT_ROOT"

# Cache the dependency classpath; rebuild only when the pom changes.
CP_FILE="target/cp.txt"
POM_HASH_FILE="target/.cp.pom-hash"
CURRENT_HASH=$(sha256sum pom.xml | cut -d' ' -f1)

if [[ ! -f "$CP_FILE" ]] || [[ ! -f "$POM_HASH_FILE" ]] || [[ "$(cat "$POM_HASH_FILE")" != "$CURRENT_HASH" ]]; then
    # Build the classpath (includes provided/test scopes — jackson-databind etc.)
    mvn -q dependency:build-classpath -Dmdep.outputFile="$CP_FILE" >/dev/null
    # Also compile (quiet, no-op if up to date).
    mvn -q compile >/dev/null
    echo "$CURRENT_HASH" > "$POM_HASH_FILE"
fi

CP="target/classes:$(cat "$CP_FILE")"

exec java \
    --add-opens=java.base/java.lang=ALL-UNNAMED \
    --add-opens=java.base/java.util=ALL-UNNAMED \
    -cp "$CP" \
    com.example.sdfcli.Main \
    "$@"
