<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>io.semanticdf</groupId>
    <artifactId>semanticdf-mcp_2.13</artifactId>
    <version>0.1.5</version>
    <packaging>jar</packaging>

    <name>semanticdf-mcp</name>
    <description>MCP server for semanticdf — exposes the library as the 5 tools in docs/agents/mcp-contract.md.</description>

    <properties>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <scala.version>2.13.18</scala.version>
        <scala.binary.version>2.13</scala.binary.version>
        <spark.version>3.5.8</spark.version>
        <semanticdf.version>0.1.2</semanticdf.version>
        <mcp.sdk.version>0.18.3</mcp.sdk.version>

        <!-- Same JVM flags as the example projects. Required for Spark 3.x on JDK 17. -->
        <mcp.run.jvmArgs>--add-opens=java.base/java.lang=ALL-UNNAMED --add-opens=java.base/java.lang.invoke=ALL-UNNAMED --add-opens=java.base/java.lang.reflect=ALL-UNNAMED --add-opens=java.base/java.io=ALL-UNNAMED --add-opens=java.base/java.net=ALL-UNNAMED --add-opens=java.base/java.nio=ALL-UNNAMED --add-opens=java.base/java.util=ALL-UNNAMED --add-opens=java.base/java.util.concurrent=ALL-UNNAMED --add-opens=java.base/java.util.concurrent.atomic=ALL-UNNAMED --add-opens=java.base/sun.nio.ch=ALL-UNNAMED --add-opens=java.base/sun.nio.cs=ALL-UNNAMED --add-opens=java.base/sun.security.action=ALL-UNNAMED --add-opens=java.base/sun.util.calendar=ALL-UNNAMED</mcp.run.jvmArgs>
    </properties>

    <dependencies>
        <!-- semanticdf library — installed locally via `mvn install` on the parent. -->
        <dependency>
            <groupId>io.semanticdf</groupId>
            <artifactId>semanticdf_2.13</artifactId>
            <version>${semanticdf.version}</version>
        </dependency>

        <!-- Official MCP Java SDK (io.modelcontextprotocol.sdk:mcp). 2.0.0 ships STDIO,
             SSE, and Streamable-HTTP server transports in a single core jar. -->
        <dependency>
            <groupId>io.modelcontextprotocol.sdk</groupId>
            <artifactId>mcp</artifactId>
            <version>${mcp.sdk.version}</version>
        </dependency>

        <!-- Jackson implementation of McpJsonMapper. Wraps an ObjectMapper
             with the Scala module registered for generic-case-class
             serialization (Envelope[T], etc.). Pinned to a Jackson
             version compatible with Spark 3.5.x's bundled Scala module
             (2.15.2) — see the jackson-databind override below. -->
        <dependency>
            <groupId>io.modelcontextprotocol.sdk</groupId>
            <artifactId>mcp-json-jackson2</artifactId>
            <version>${mcp.sdk.version}</version>
        </dependency>

        <!-- Spark SQL — required by semanticdf's runtime. The MCP server initializes
             a single SparkSession at startup to load the data-config block. -->
        <dependency>
            <groupId>org.apache.spark</groupId>
            <artifactId>spark-sql_${scala.binary.version}</artifactId>
            <version>${spark.version}</version>
            <scope>provided</scope>
        </dependency>

        <!-- Scala standard library (matches the parent project's Scala version). -->
        <dependency>
            <groupId>org.scala-lang</groupId>
            <artifactId>scala-library</artifactId>
            <version>${scala.version}</version>
        </dependency>

        <!-- Jackson Databind - pinned to 2.15.2 to match Spark 3.5.x's bundled
             jackson-module-scala 2.15.2. The MCP SDK's mcp-json-jackson2
             declares jackson-databind 2.20.1 which is INCOMPATIBLE with
             Spark's scala module (it does a strict version range check at
             registerModule time and throws). Pinning to 2.15.x lets us use
             the Scala module (for Envelope[T] serialization) without
             crashing Spark's RDDOperationScope$ static initializer. -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
            <version>2.15.2</version>
        </dependency>

        <!-- Jackson Scala Module - explicit compile-scope dep. Spark brings
             this in transitively as 'provided' (for its own internal use),
             but we need it at runtime to register on our ObjectMapper
             (so generic case classes like Envelope[T] serialize correctly).
             Version 2.15.2 matches the pinned jackson-databind. -->
        <dependency>
            <groupId>com.fasterxml.jackson.module</groupId>
            <artifactId>jackson-module-scala_2.13</artifactId>
            <version>2.15.2</version>
        </dependency>

        <!-- YAML reader for the data-config file (data sources, formats, read options). -->
        <dependency>
            <groupId>org.yaml</groupId>
            <artifactId>snakeyaml</artifactId>
            <version>2.2</version>
        </dependency>

        <!-- Test deps -->
        <dependency>
            <groupId>org.scalatest</groupId>
            <artifactId>scalatest_${scala.binary.version}</artifactId>
            <version>3.2.19</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>net.alchim31.maven</groupId>
                <artifactId>scala-maven-plugin</artifactId>
                <version>4.9.2</version>
                <executions>
                    <execution>
                        <id>scala-compile-first</id>
                        <phase>process-resources</phase>
                        <goals><goal>compile</goal></goals>
                    </execution>
                    <execution>
                        <id>scala-test-compile-first</id>
                        <phase>process-test-resources</phase>
                        <goals><goal>testCompile</goal></goals>
                    </execution>
                </executions>
                <configuration>
                    <scalaVersion>${scala.version}</scalaVersion>
                </configuration>
            </plugin>

            <!-- ScalaTest runner. Picks up classes ending in `Spec` (per
                 `<suffixes>Spec</suffixes>`) like the parent project.
                 Forks the JVM with the same add-opens flags the example projects use
                 (Spark 3.5.x on JDK 17 cannot access sun.nio.ch.DirectBuffer otherwise). -->
            <plugin>
                <groupId>org.scalatest</groupId>
                <artifactId>scalatest-maven-plugin</artifactId>
                <version>2.2.0</version>
                <configuration>
                    <suffixes>Spec</suffixes>
                    <reportsDirectory>${project.build.directory}/surefire-reports</reportsDirectory>
                    <junitxml>.</junitxml>
                    <filereports>semanticdf-test-suite.txt</filereports>
                    <argLine>${mcp.run.jvmArgs}</argLine>
                </configuration>
                <executions>
                    <execution>
                        <id>test</id>
                        <goals>
                            <goal>test</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>exec-maven-plugin</artifactId>
                <version>3.6.3</version>
                <configuration>
                    <mainClass>io.semanticdf.mcp.Main</mainClass>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
